# ServiceSentry — Docker environment template
# ============================================
# Copy this file to "docker/.env" and edit it. Both compose files load it via
# `env_file: .env`, so your secrets and custom settings stay OUT of the
# (committed) compose files. docker/.env is gitignored.
#
#   cp docker/env.example docker/.env
#   # edit docker/.env  (at minimum change SS_PASSWORD)
#   docker compose -f docker/docker-compose.monolithic.yml up -d
#
# All settings use the SS_ prefix (TZ is the Docker standard, kept as-is).
# Notes:
# - Per-topology values live in the compose files, NOT here: SS_SERVICE_ROLE and
#   the *_EMBEDDED gates (the microservices web sets SS_MONITORING_EMBEDDED /
#   SS_SYSLOG_EMBEDDED / SS_EVENTS_EMBEDDED to 0 so dedicated containers own each
#   service; monolithic leaves them on). The web bind/port (SS_WEB_HOST/
#   SS_WEB_PORT) and the published port also stay in compose.
# - Empty value = leave the saved config value untouched. Any value set here is
#   applied at runtime and shown read-only (locked) in the web UI.

# ── Credentials (first run creates the initial admin; change before exposing) ──
SS_USERNAME=admin
SS_PASSWORD=admin

# ── Database ──────────────────────────────────────────────────────────────────
# The monolithic compose uses SQLite (no DB vars needed). The microservices
# compose runs a shared MariaDB and reads these (SS_DB_*): the app processes use
# SS_DB_PASSWORD/NAME/USER, and the db container also provisions itself from them
# (driver/host/port are pinned in that compose file). Required there:
SS_DB_PASSWORD=                # app DB password (REQUIRED for microservices)
SS_DB_ROOT_PASSWORD=           # MariaDB root password (REQUIRED for microservices)
SS_DB_NAME=servicesentry
SS_DB_USER=servicesentry
# Advanced / non-compose use: point at an external database directly.
#   SS_DB_DRIVER=mysql         # sqlite | mysql | postgresql  ('mariadb' = alias of mysql)
#   SS_DB_HOST=db
#   SS_DB_PORT=3306

# ── Syslog database (microservices: dedicated DB for syslog messages) ──────────
# The microservices compose runs a SECOND MariaDB (syslog-db) so high-volume
# syslog ingestion stays off the main DB. The syslog + web containers read these
# (SS_SYSLOG_DB_*); the syslog-db container provisions itself from them. Required
# for the microservices topology (driver/host/port are pinned in that compose):
SS_SYSLOG_DB_PASSWORD=         # syslog DB password (REQUIRED for microservices)
SS_SYSLOG_DB_ROOT_PASSWORD=    # syslog MariaDB root password (REQUIRED for microservices)
SS_SYSLOG_DB_NAME=servicesentry_syslog
SS_SYSLOG_DB_USER=servicesentry
# Advanced: ENABLED=1 routes syslog to its own DB (set in the microservices
# compose). Leave unset/0 to keep syslog in the main DB (monolithic default).
#   SS_SYSLOG_DB_ENABLED=1
#   SS_SYSLOG_DB_DRIVER=mysql  # sqlite | mysql | postgresql
#   SS_SYSLOG_DB_HOST=syslog-db
#   SS_SYSLOG_DB_PORT=3306

# ── Syslog receiver listener (standalone syslog role) ──────────────────────────
# Override where the syslog receiver binds, straight from the environment;
# otherwise the bind host/ports come from the saved config (editable in the web
# UI). SS_SYSLOG_PORT overrides BOTH the UDP and TCP ports (TLS keeps its
# configured port). Empty = use the saved config.
#   SS_SYSLOG_HOST=0.0.0.0
#   SS_SYSLOG_PORT=514

# ── Event processor (decoupled notification-rule evaluation) ───────────────────
# Evaluates the event-notification rules (audit/syslog) and dispatches them. It is
# decoupled from ingestion: it reads stored rows by cursor, so a flood of syslog
# never blocks reception. In the microservices topology it runs as its own
# container (SS_SERVICE_ROLE=events) and the web sets SS_EVENTS_EMBEDDED=0 so a
# single worker owns it (both pinned in the compose file). In the monolithic
# topology the web admin hosts it embedded (the default). Its behaviour
# (events|mode = embedded|external|off, poll interval) is configured in the web UI
# → Configuration → Notifications, not via env vars.
#   SS_EVENTS_EMBEDDED=0         # set on the web container in the microservices compose

# ── Traefik / public TLS (microservices-traefik topology only) ─────────────────
# Used by docker-compose.microservices-traefik.yml to publish over HTTPS with an
# automatic Let's Encrypt certificate. Point SS_DOMAIN's DNS at this host first.
SS_DOMAIN=                     # public FQDN, e.g. monitor.example.com (REQUIRED for traefik)
SS_ACME_EMAIL=                 # email for Let's Encrypt registration (REQUIRED for traefik)

# ── Appearance / locale ───────────────────────────────────────────────────────
SS_LANG=en_EN
SS_DARK_MODE=false

# ── Monitoring ────────────────────────────────────────────────────────────────
# Scheduler / worker period in seconds (used by the embedded scheduler and the worker).
SS_CHECK_INTERVAL=300
# Whether the monitor is enabled and whether the EMBEDDED scheduler launches at web
# boot are config flags edited in the web UI (Configuration → Monitoring: enabled +
# autostart) and operated from the Services tab — not normally env vars. In the
# microservices topology the web container sets SS_MONITORING_EMBEDDED=0 (in the
# compose file) so the dedicated worker owns the scheduler; a standalone --monitor
# worker ignores ``autostart`` and runs whenever monitoring is enabled.
#   SS_MONITORING_EMBEDDED=0     # set on the web container in the microservices compose

# ── Distributed control plane (microservices only) ─────────────────────────────
# When services run as dedicated containers, the web admin and each service
# coordinate through the SHARED DATABASE (desired state + heartbeat + a command
# queue); a service reconciles on a timer, so control works with no token. Set a
# shared token to ALSO enable the instant HTTP "poke" (POST /control/reconcile),
# so a disable / run-now takes effect immediately instead of at the next poll.
# Use the same token in every container. Empty = poke off (periodic reconcile only).
SS_CONTROL_TOKEN=              # shared bearer token for the control poke (recommended)
#   SS_CONTROL_PORT=8765       # control listener port on worker/syslog/events
#   SS_CONTROL_ADVERTISE=worker  # address the web pokes (default: the host/pod name)

# ── Security ──────────────────────────────────────────────────────────────────
SS_SECURE_COOKIES=false       # true when serving over HTTPS
SS_REMEMBER_ME_DAYS=30
SS_PROXY_COUNT=0              # number of reverse proxies in front
SS_PUBLIC_URL=               # public host[:port] behind a proxy (empty = derive from the request)
SS_FORCE_HTTPS=false         # redirect HTTP requests to HTTPS
SS_FORCE_FQDN=false          # redirect other hosts to SS_PUBLIC_URL (requires it set)

# ── Public status page ────────────────────────────────────────────────────────
SS_PUBLIC_STATUS=false
SS_PUBLIC_STATUS_DETAIL=false # show per-item detail on the public status page
SS_STATUS_REFRESH_SECS=60
SS_STATUS_LANG=               # defaults to SS_LANG when empty

# ── Audit log ─────────────────────────────────────────────────────────────────
SS_AUDIT_MAX_ENTRIES=500

# ── Telegram notifications (secrets — leave blank to disable) ──────────────────
SS_TELEGRAM_TOKEN=
SS_TELEGRAM_CHAT_ID=
SS_TELEGRAM_GROUP_MESSAGES=false

# ── Misc ──────────────────────────────────────────────────────────────────────
TZ=UTC
SS_VERBOSE=false              # true forces debug output (any role)
# Log verbosity for any role: off | debug | info | warning | error. Overrides the
# saved config (SS_VERBOSE/-v still forces debug). Empty = use the saved value.
SS_LOG_LEVEL=
