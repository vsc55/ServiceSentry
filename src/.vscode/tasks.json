{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup venv",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy","Bypass","-File","${workspaceFolder}/setup_env.ps1"],
      "runOptions": { "runOn": "folderOpen" },
      "problemMatcher": []
    },
    {
      "label": "🔄 Watch & Restart Web",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python",
      "args": ["${workspaceFolder}/dev_watch.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "echo": false
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "flake8 full",
      "type": "shell",
      "command": ".venv/Scripts/python.exe",
      "args": ["-m", "flake8", "."],
      "problemMatcher": [
        "$flake8"
      ]
    }
  ]
}