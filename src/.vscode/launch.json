{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🖥 Python: Main.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env.dev"
        },
        {
            "name": "🖥 Python: Main.py Web",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env.dev",
            "args": [
                "--web"
            ],
        },
        {
            "name": "🔒 Python: Web (Env Vars)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env.dev",
            "args": [
                "--web"
            ],
            "env": {
                // ── Valores válidos — campo bloqueado en la UI ──────────────
                "SS_DARK_MODE": "true",
                "SS_REMEMBER_ME_DAYS": "7",
                "SS_LANG": "es_ES",
                // ── Valores inválidos — warning en consola, campo NO bloqueado
                // Descomenta para probar:
                // "SS_AUDIT_MAX_ENTRIES": "Pepito",   // int inválido
                // "SS_PUBLIC_STATUS": "quizas",       // bool inválido
                // "SS_PORT": "99999",                 // int fuera de rango
                // "SS_LANG": "klingon",               // idioma no soportado
                // ── Credenciales primer arranque ────────────────────────────
                "SS_USERNAME": "admin",
                "SS_PASSWORD": "admin"
            }
        },
        {
            "name": "🩺 Python: pytest (usa pytest.ini)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/Scripts/pytest.exe",
            "args": [
                "-c",
                "${workspaceFolder}/pytest.ini",
                "tests",
                "watchfuls"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "🐍 Python: Archivo actual",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}