{
    "__module__": {
        "api_ver": "v1",
        "enabled": {"type": "bool", "default": true},
        "threads": {"type": "int",  "default": 5, "min": 0, "inherit_blank": true, "max": 100},
        "timeout": {"type": "int",  "default": 15, "min": 0, "inherit_blank": true, "max": 600}
    },
    "__history__": {"field": null, "unit": null, "label": "Service Status"},
    "__host_profile__": {"key": "ssh", "address_field": "ssh_host",
        "fields": ["ssh_host", "ssh_port", "ssh_user", "ssh_password",
                   "ssh_key", "ssh_key_string", "ssh_verify_host"]},
    "__host_multiple__": true,
    "list": {
        "__discovery__": "discover",
        "__discovery_field__": "service",
        "__discovery_uid_key__": true,
        "__discovery_label_template__": "{host} - {name}",
        "__check_title_field__": "label",
        "__title_editable__": true,
        "__new_item_fields__": ["label", "service"],
        "__field_order__": ["enabled", "label", "service", "expected", "remediation"],
        "enabled":     {"type": "bool",   "default": true},
        "label":       {"type": "str",   "default": ""},
        "service":     {"type": "str",   "default": "", "group": "service"},
        "expected":    {"type": "str",   "default": "running", "options": ["running", "stopped"], "group": "status"},
        "remediation": {"type": "bool",  "default": false, "group": "remediation"}
    }
}
