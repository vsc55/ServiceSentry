{
    "__icon__": "bi-clock-history",
    "__module__": {
        "enabled":    {"type": "bool",  "default": true},
        "threads":    {"type": "int",   "default": 3,   "min": 0, "inherit_blank": true,   "max": 100},
        "max_offset": {"type": "float", "default": 5.0, "min": 0.1, "max": 3600.0},
        "timeout":    {"type": "int",   "default": 5,   "min": 0, "inherit_blank": true,   "max": 30}
    },
    "__history__": {"field": "offset_seconds", "unit": "s", "label": "NTP Offset"},
    "__host_profile__": {"key": "ntp", "address_field": "server", "fields": ["server"]},
    "list": {
        "__check_title_field__": "label",
        "__title_editable__": true,
        "__discovery_uid_key__": true,
        "__discovery_label_template__": "{host}",
        "__new_item_fields__": ["label"],
        "__field_order__": ["enabled", "label", "server", "port", "timeout", "max_offset"],
        "enabled":    {"type": "bool",  "default": true},
        "label":      {"type": "str",   "default": ""},
        "server":     {"type": "str",   "default": "pool.ntp.org", "group": "connection"},
        "port":       {"type": "int",   "default": 0, "min": 0, "max": 65535, "placeholder": 123, "group": "connection"},
        "max_offset": {"type": "float", "default": 0.0, "min": 0.0, "max": 3600.0, "placeholder_module": "max_offset", "group": "alerts"},
        "timeout":    {"type": "int",   "default": 0,   "min": 0,   "max": 30,     "placeholder_module": "timeout", "group": "connection"}
    }
}
