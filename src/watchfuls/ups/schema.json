{
    "__module__": {
        "enabled": {"type": "bool", "default": true},
        "threads": {"type": "int",  "default": 3,  "min": 1, "max": 100},
        "timeout": {"type": "int",  "default": 10, "min": 1, "max": 60},
        "alert_battery": {"type": "int", "default": 20, "min": 0, "max": 100},
        "alert_runtime": {"type": "int", "default": 10, "min": 0, "max": 1440},
        "alert_load":    {"type": "int", "default": 0,  "min": 0, "max": 100}
    },
    "__history__": {"field": "battery_charge", "unit": "%", "label": "Battery Charge",
                    "fields": {"battery_charge": {"unit": "%"},
                               "runtime": {"unit": "min"},
                               "load": {"unit": "%"}}},
    "__host_profile__": {"key": "nut", "address_field": "host", "fields": ["host"]},
    "__credential__": {
        "type": "nut_auth",
        "fields": [
            {"name": "user",     "kind": "text",     "label": "user"},
            {"name": "password", "kind": "password", "secret": true, "label": "password"}
        ]
    },
    "__host_multiple__": true,
    "list": {
        "__field_order__": [
            "enabled",
            "host", "port", "ups_name", "timeout",
            "user", "password",
            "alert_on_battery", "alert_battery", "alert_runtime", "alert_load"
        ],
        "__check_title_field__": "ups_name",
        "__new_item_fields__": ["ups_name"],
        "__test__": "/api/v1/watchfuls/ups/test_connection",
        "enabled":  {"type": "bool", "default": true},

        "host":     {"type": "str",  "default": "", "group": "connection"},
        "port":     {"type": "int",  "default": 0, "min": 0, "max": 65535, "placeholder": 3493, "group": "connection"},
        "ups_name": {"type": "str",  "default": "ups", "group": "connection"},
        "timeout":  {"type": "int",  "default": 0, "min": 0, "max": 60, "placeholder_module": "timeout", "group": "connection"},

        "user":     {"type": "str",  "default": "", "group": "auth"},
        "password": {"type": "str",  "default": "", "sensitive": true, "group": "auth"},

        "alert_on_battery": {"type": "bool", "default": true, "group": "alerts"},
        "alert_battery":    {"type": "int",  "default": 0, "min": 0, "max": 100,
                             "placeholder_module": "alert_battery", "group": "alerts"},
        "alert_runtime":    {"type": "int",  "default": 0, "min": 0, "max": 1440,
                             "placeholder_module": "alert_runtime", "group": "alerts"},
        "alert_load":       {"type": "int",  "default": 0, "min": 0, "max": 100,
                             "placeholder_module": "alert_load", "group": "alerts"}
    }
}
