{
    "__icon__": "bi-globe2",
    "__module__": {
        "enabled":    {"type": "bool", "default": true},
        "threads":    {"type": "int",  "default": 5, "min": 0, "inherit_blank": true, "max": 100},
        "nameserver": {"type": "str",  "default": "", "placeholder": "system resolver"},
        "timeout":    {"type": "int",  "default": 5, "min": 0, "inherit_blank": true, "max": 30}
    },
    "__history__": {"field": "response_time", "unit": "ms", "label": "DNS Resolution Time"},
    "__host_profile__": {"key": "ssh", "address_field": "ssh_host",
        "fields": ["ssh_host", "ssh_port", "ssh_user", "ssh_password",
                   "ssh_key", "ssh_key_string", "ssh_verify_host"]},
    "__host_multiple__": true,
    "list": {
        "__discovery__": "discover",
        "__discovery_method__": "POST",
        "__discovery_field__": "host",
        "__discovery_type_field__": "record_type",
        "__discovery_type_store_field__": "record_type",
        "__discovery_value_field__": "expected",
        "__discovery_uid_key__": true,
        "__discovery_label_template__": "{host} - {type} {name}",
        "__check_title_field__": "label",
        "__title_editable__": true,
        "__new_item_fields__": ["label", "host", "record_type"],
        "__field_order__": ["enabled", "label", "nameserver", "timeout", "host", "record_type", "expected"],
        "__discovery_subtitle__": "{value}",
        "__discovery_dedup_with_type__": true,
        "__discovery_probe_types__": ["A", "AAAA", "MX", "TXT", "NS", "SOA", "CNAME", "CAA", "SRV"],
        "__discovery_categories__": {
            "address": {"icon": "bi-globe2",     "color": "#38bdf8"},
            "mail":    {"icon": "bi-envelope",   "color": "#f59e0b"},
            "ns":      {"icon": "bi-diagram-3",  "color": "#8b5cf6"},
            "alias":   {"icon": "bi-signpost-2", "color": "#10b981"},
            "text":    {"icon": "bi-fonts",      "color": "#4ade80"},
            "srv":     {"icon": "bi-hdd-stack",  "color": "#64748b"},
            "other":   {"icon": "bi-question-circle", "color": "var(--bs-secondary-color)"}
        },
        "__discovery_inputs__": [
            {"key": "domain", "type": "str", "ui": "discover_domain",
             "placeholder": "example.com", "required": true},
            {"key": "axfr", "type": "bool", "ui": "discover_axfr"},
            {"key": "axfr_server", "type": "str", "ui": "discover_axfr_server",
             "placeholder": "ns1.example.com / IP", "depends_on": "axfr"}
        ],
        "enabled":     {"type": "bool", "default": true},
        "label":       {"type": "str",  "default": ""},
        "host":        {"type": "str",  "default": "", "group": "query"},
        "record_type": {"type": "str",  "default": "A",
                        "options": ["A", "AAAA", "CNAME", "MX", "TXT", "NS", "PTR", "SOA"], "group": "query"},
        "nameserver":  {"type": "str",  "default": "", "placeholder": "system resolver", "placeholder_module": "nameserver", "group": "connection"},
        "expected":    {"type": "str",  "default": "", "group": "query"},
        "timeout":     {"type": "int",  "default": 0, "min": 0, "max": 30, "placeholder_module": "timeout", "group": "connection"}
    }
}
