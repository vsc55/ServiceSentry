{
    "__module__": {
        "api_ver":   "v1",
        "enabled":   {"type": "bool", "default": true},
        "threads":   {"type": "int",  "default": 5,  "min": 1, "max": 100},
        "timeout":   {"type": "int",  "default": 15, "min": 1, "max": 600},
        "min_count": {"type": "int",  "default": 1,  "min": 1, "max": 1000}
    },
    "__history__": {"field": "count", "unit": "", "label": "Process Count"},
    "__host_profile__": {"key": "ssh", "address_field": "ssh_host",
        "fields": ["ssh_host", "ssh_port", "ssh_user", "ssh_password",
                   "ssh_key", "ssh_key_string", "ssh_verify_host"]},
    "__host_multiple__": true,
    "list": {
        "__discovery__":         "discover",
        "__discovery_field__":   "process",
        "__key_mirrors_field__": "process",
        "__check_title_field__": "process",
        "enabled":   {"type": "bool", "default": true},
        "process":   {"type": "str",  "default": "", "placeholder": "__key__"},
        "min_count": {"type": "int",  "default": 0,  "min": 0, "max": 1000, "placeholder_module": "min_count"}
    }
}
