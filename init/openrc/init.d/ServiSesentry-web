#!/sbin/openrc-run
# ServiSesentry web admin panel
# Configuration: /etc/conf.d/ServiSesentry-web

: "${SS_PYTHON:=/usr/bin/python3}"
: "${SS_APP:=/opt/ServiSesentry/main.py}"
: "${SS_WEB_HOST:=0.0.0.0}"
: "${SS_WEB_PORT:=8080}"

command="${SS_PYTHON}"
command_args="${SS_APP} --web --web-host ${SS_WEB_HOST} --web-port ${SS_WEB_PORT}"
command_background=true
# shellcheck disable=SC2154  # RC_SVCNAME is set by OpenRC at runtime
pidfile="/var/run/${RC_SVCNAME}.pid"

depend() {
	use net
	need localmount
}
