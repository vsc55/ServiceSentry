# ServiSesentry monitoring daemon — OpenRC configuration
# This file is sourced by /etc/init.d/ServiSesentry

# Python interpreter
SS_PYTHON="/usr/bin/python3"

# Application path
SS_APP="/opt/ServiSesentry/main.py"

# Startup arguments
# --monitor      run the service monitor continuously (-t 0 = a single pass)
# -c             clear the saved check status on start
# -t <seconds>   override the check interval from config.json (e.g. -t 120)
SS_ARGS="--monitor -c"
